# Texas Ally — Developer Environment
# Copy to .env and fill in your values

# =============================================================================
# Database (required)
# =============================================================================

# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=your-super-secret-postgres-password

# JWT secret — at least 32 characters
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# Supabase JWT tokens — for local dev, use the demo tokens below.
# For production, generate at: https://supabase.com/docs/guides/self-hosting
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# =============================================================================
# API Keys (required for specific imports)
# =============================================================================

# Census ACS demographics — free, instant registration
# Get yours at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# HERE Maps — for local resource/POI lookups
# Get yours at: https://developer.here.com/
HERE_API_KEY=

# =============================================================================
# App Configuration (defaults work for local dev)
# =============================================================================

SUPABASE_URL=http://localhost:8000
SUPABASE_PUBLIC_URL=http://localhost:8000
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Neighborhoods API
BACKEND_PORT=3000
VITE_BACKEND_URL=http://localhost:3000

# =============================================================================
# Production DB clone (for ./dev-setup.sh --db-clone)
# =============================================================================

# SSH connection to production server
# PROD_HOST=
# PROD_USER=
# PROD_TA_PATH=/home/lib/ta-projects

# =============================================================================
# Optional services (not required for core development)
# =============================================================================

# n8n workflow automation
# N8N_API_URL=https://your-instance.app.n8n.cloud
# N8N_API_KEY=

# Zapier MCP
# ZAPIER_MCP_URL=
# ZAPIER_API_KEY=
